# ============================================================
# UDAYA PACS API LOCAL ENV (template)
# ============================================================
# Keep real secrets only on the server/build machine. Do not commit real passwords, API keys, or tokens.
# Use hostnames for QA/prod. Keep browser API URL relative as /pacsApi when frontend nginx proxies to API.
#
# Commands:
#   Build/deploy local: bash ./scripts/stack.sh local deploy --build
#   Health local:       bash ./scripts/stack.sh local health
#   Logs local:         bash ./scripts/stack.sh local logs
# ============================================================

# ------------------------------------------------------------
# 01 Runtime and container
# Use *_API_BIND_HOST=auto for QA/prod. Local should stay 127.0.0.1.
# ------------------------------------------------------------
TZ=Asia/Phnom_Penh
LOCAL_API_BIND_HOST=127.0.0.1
LOCAL_API_PORT=8080
LOCAL_API_DOCKER_IP=

# ------------------------------------------------------------
# 02 Storage and keys
# ------------------------------------------------------------
KEY_PATH=./src/main/resources/key
HOSPITAL_IMAGE_ROOT_PATH=/var/ut-image
PACS_RESULT_UPLOAD_ROOT=/var/ut-image

# ------------------------------------------------------------
# 03 Database
# Use DB hostname, for example jdbc:postgresql://utdatabase.lan:5432/emr_pacs_db.
# ------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://pacs-db.local.lan:5432/emr_pacs_db
SPRING_DATASOURCE_USERNAME=pacs_app_local_rw
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_LOCAL_DB_PASSWORD

# ------------------------------------------------------------
# 04 Security and JWT
# ------------------------------------------------------------
LOCAL_SECURITY_JWT_REFRESH_TOKEN_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_REFRESH_TOKEN_KEY

# ------------------------------------------------------------
# 05 Public URLs, CORS, and host aliases
# API_HOST_ALIASES format: hostname:auto or hostname:ip. Leave blank when DNS works.
# ------------------------------------------------------------
LOCAL_API_AUTH_URL=http://localhost:8080/pacsApi
LOCAL_SPRINGDOC_SERVER_URL=
CORS_ALLOWED_ORIGINS=http://localhost:4173,http://localhost:3005
CORS_ALLOW_CREDENTIALS=false

# ------------------------------------------------------------
# 06 Client allow-list
# ------------------------------------------------------------
APP_SECURITY_CLIENT_ALLOW_PATHS=/worklist/worklist-received-study
APP_SECURITY_CLIENT_ALLOW_CLIENT_IDS=

# ------------------------------------------------------------
# 07 PACS result API
# ------------------------------------------------------------
PACS_RESULT_STATIC_AUTH_ENABLED=true
PACS_RESULT_API_KEY=replace_with_matching_local_result_api_key
PACS_RESULT_MAX_IMAGE_BYTES=10485760

# ------------------------------------------------------------
# 08 Redis cache
# ------------------------------------------------------------
APP_CACHE_PROVIDER=redis
APP_CACHE_TTL_SECONDS=600
APP_CACHE_MAX_ENTRIES=5000
APP_CACHE_REDIS_HEALTH_ENABLED=true
APP_CACHE_REDIS_KEY_PREFIX=udaya_pacs_local
REDIS_IMAGE=redis:7-alpine
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_TIMEOUT=2s
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
LOCAL_REDIS_CONTAINER_NAME=udaya_pacs_local_redis
LOCAL_REDIS_HOST_PORT=6379
LOCAL_REDIS_NETWORK_NAME=udaya_pacs_local_network
LOCAL_REDIS_PASSWORD=CHANGE_ME_LOCAL_REDIS_PASSWORD

# ------------------------------------------------------------
# 09 DICOM upload, health, and package builder
# ------------------------------------------------------------
PACS_CACHE_SCHEDULER_ENABLED=true
PACS_PARTITION_SCHEDULER_ENABLED=true
PACS_DICOM_UPLOAD_INSTANCE_PARALLELISM=24
PACS_DICOM_UPLOAD_INSTANCE_MAX_ATTEMPTS=8
PACS_DICOM_UPLOAD_INSTANCE_RETRY_BACKOFF_MS=500
PACS_DICOM_UPLOAD_IN_MEMORY_ENTRY_MAX_BYTES=1048576
PACS_DICOM_UPLOAD_MAX_CONCURRENT_PROCESSING_JOBS=1
DICOM_SERVER_HEALTH_TIMEOUT_MS=5000
DICOM_SERVER_HEALTH_OFFLINE_FAILURE_THRESHOLD=3
DICOM_SERVER_HEALTH_OFFLINE_GRACE_MS=180000
PACS_DICOM_SERVER_PACKAGE_INCLUDE_BASE_IMAGE=false
PACS_DICOM_SERVER_BASE_IMAGE_ARCHIVE_HOST_PATH=../dicom_server_ksfh/images/dicom_server_base.tar
PACS_DICOM_SERVER_BASE_IMAGE_ARCHIVE_CONTAINER_PATH=/app/dicom-server-images/dicom_server_base.tar
PACS_DICOM_SERVER_PACKAGE_BASE_IMAGE_ARCHIVE_PATH=/app/dicom-server-images/dicom_server_base.tar
PACS_DICOM_SERVER_PACKAGE_MAX_EMBEDDED_BASE_IMAGE_BYTES=67108864

# ------------------------------------------------------------
# 10 Optional integrations and deploy notifications
# ------------------------------------------------------------
DEPLOY_TELEGRAM_ENABLED=true
DEPLOY_TELEGRAM_CHAT_ID=
DEPLOY_TELEGRAM_API_TOKEN=
