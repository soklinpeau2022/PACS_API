# DB-only deploy. Copy to .env.db and edit values.

# Runtime
TZ=Asia/Phnom_Penh
PACS_DB_COMPOSE_PROJECT_NAME=udaya_pacs_db
PACS_DB_CONTAINER_NAME=udaya_pacs_db
PACS_DB_PORT=5432
PACS_DB_BIND_ADDRESS=192.168.8.11
PACS_DB_INIT_DIR=./init

# Database
PACS_DB_NAME=emr_pacs_db
PACS_DB_USER=pacs_app_qa
PACS_DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# API scheduler flags (set in the API runtime environment).
PACS_CACHE_SCHEDULER_ENABLED=true
PACS_PARTITION_SCHEDULER_ENABLED=true

# QA DB server baseline:
# - IP: 192.168.8.11
# - IP: 192.168.8.11
# Keep port 5432 firewalled so only 192.168.8.10 can connect.

# Docker Compose creates an internal DB network automatically.
PACS_DB_NETWORK_NAME=udaya_pacs_db-network
