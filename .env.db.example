# ============================================================
# UDAYA PACS DB QA ENV (template)
# ============================================================
# Keep real secrets only on the server/build machine. Do not commit real passwords, API keys, or tokens.
# Use hostnames for QA/prod. Keep browser API URL relative as /pacsApi when frontend nginx proxies to API.
#
# Commands:
#   Build DB bundle:    bash ./scripts/package-db-deploy.sh --target qa --no-data
#   Start DB server:    sudo bash ./scripts/deploy-db.sh
#   DB health:          sudo docker inspect <db-container> --format '{{.State.Health.Status}}'
# ============================================================

# ------------------------------------------------------------
# 01 Runtime and container
# Bind DB to a hostname/private interface in deployed environments.
# ------------------------------------------------------------
TZ=Asia/Phnom_Penh
PACS_DB_COMPOSE_PROJECT_NAME=udaya_pacs_db
PACS_DB_CONTAINER_NAME=udaya_pacs_db
PACS_DB_PORT=5432
PACS_DB_BIND_ADDRESS=auto
PACS_DB_INIT_DIR=./init

# ------------------------------------------------------------
# 02 Database credentials
# ------------------------------------------------------------
PACS_DB_NAME=emr_pacs_db
PACS_DB_USER=pacs_app_qa
PACS_DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ------------------------------------------------------------
# 03 Network
# ------------------------------------------------------------
PACS_DB_NETWORK_NAME=udaya_pacs_db-network

# ------------------------------------------------------------
# 04 Schedulers
# ------------------------------------------------------------
PACS_CACHE_SCHEDULER_ENABLED=true
PACS_PARTITION_SCHEDULER_ENABLED=true
