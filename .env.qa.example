# QA API profile. Copy to .env.qa and edit values.

# Runtime
TZ=Asia/Phnom_Penh
APP_IMAGE=udaya_pacs_qa_api:latest
API_COMPOSE_PROJECT_NAME=udaya_pacs_qa_api
QA_API_CONTAINER_NAME=udaya_pacs_qa_api
QA_API_PORT=8080
KEY_PATH=/var/ut-key
HOSPITAL_IMAGE_HOST_PATH=/var/ut-image
HOSPITAL_IMAGE_ROOT_PATH=/var/ut-image

# Database
QA_SPRING_DATASOURCE_URL=jdbc:postgresql://192.168.8.11:5432/emr_pacs_db
QA_SPRING_DATASOURCE_USERNAME=pacs_app_qa
QA_SPRING_DATASOURCE_PASSWORD=CHANGE_ME_QA_DB_PASSWORD

# JWT
QA_SECURITY_JWT_REFRESH_TOKEN_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_REFRESH_TOKEN_KEY
SECURITY_JWT_PRIVATE_KEY=file:/app/config/key/private_key.pem
SECURITY_JWT_PUBLIC_KEY=file:/app/config/key/public_key.pem
SECURITY_JWT_KEY_ID=replace_with_stable_key_id

# API URLs
QA_API_AUTH_URL=http://192.168.8.10:8080/pacsApi
QA_SPRINGDOC_SERVER_URL=http://192.168.8.10:8080/pacsApi

# Browser access
CORS_ALLOWED_ORIGINS=http://192.168.8.10:4173,http://192.168.8.10:3005
CORS_ALLOW_CREDENTIALS=false

# UDAYA_DICOM_SERVER callback clients
APP_SECURITY_CLIENT_ALLOW_PATHS=/worklist/worklist-received-study
APP_SECURITY_CLIENT_ALLOW_CLIENT_IDS=

# PACS result upload
PACS_RESULT_STATIC_AUTH_ENABLED=true
PACS_RESULT_API_KEY=replace_with_matching_qa_result_api_key
PACS_RESULT_UPLOAD_ROOT=/var/ut-image
PACS_RESULT_MAX_IMAGE_BYTES=10485760

# QA topology notes:
# - PAC System server: 192.168.8.10
# - Database server: 192.168.8.11
# - UDAYA_DICOM_SERVER host: 192.168.8.12
# Configure each DICOM Server record in the UI with API/Internal Base URL:
#   http://192.168.8.12:8042
# and Viewer Base URL:
#   http://192.168.8.10:3005

# Optional integrations
QA_SPRING_MAIL_USERNAME=
QA_SPRING_MAIL_PASSWORD=
QA_TELEGRAM_CHAT_ID=
QA_TELEGRAM_API_TOKEN=

# Deploy Telegram notifications
DEPLOY_TELEGRAM_ENABLED=true
DEPLOY_TELEGRAM_CHAT_ID=
DEPLOY_TELEGRAM_API_TOKEN=
REDIS_MAXMEMORY_POLICY=allkeys-lru
APP_CACHE_PROVIDER=redis
REDIS_PORT=6379
REDIS_MAXMEMORY=512mb
REDIS_IMAGE=redis:7-alpine
APP_CACHE_MAX_ENTRIES=5000
REDIS_DATABASE=0
APP_CACHE_TTL_SECONDS=600
REDIS_TIMEOUT=2s
APP_CACHE_REDIS_HEALTH_ENABLED=true
APP_CACHE_REDIS_KEY_PREFIX=udaya_pacs_qa
QA_REDIS_CONTAINER_NAME=udaya_pacs_qa_redis
QA_REDIS_HOST_PORT=6380
QA_REDIS_NETWORK_NAME=udaya_pacs_qa_network
QA_REDIS_PASSWORD=CHANGE_ME_QA_REDIS_PASSWORD
PACS_CACHE_SCHEDULER_ENABLED=true
PACS_PARTITION_SCHEDULER_ENABLED=true
PACS_DICOM_UPLOAD_INSTANCE_PARALLELISM=24
PACS_DICOM_UPLOAD_INSTANCE_MAX_ATTEMPTS=8
PACS_DICOM_UPLOAD_INSTANCE_RETRY_BACKOFF_MS=500
PACS_DICOM_UPLOAD_IN_MEMORY_ENTRY_MAX_BYTES=1048576
PACS_DICOM_UPLOAD_MAX_CONCURRENT_PROCESSING_JOBS=1
DICOM_SERVER_HEALTH_TIMEOUT_MS=5000
DICOM_SERVER_HEALTH_OFFLINE_FAILURE_THRESHOLD=3
DICOM_SERVER_HEALTH_OFFLINE_GRACE_MS=180000
