# ============================================================
# UDAYA PACS API PROD ENV (template)
# ============================================================
# Keep real secrets only on the server/build machine. Do not commit real passwords, API keys, or tokens.
# Use hostnames for QA/prod. Keep browser API URL relative as /pacsApi when frontend nginx proxies to API.
#
# Commands:
#   Build bundle:       bash ./scripts/package-deploy.sh --target prod
#   Deploy on server:   sudo bash ./scripts/stack.sh prod deploy --no-build
#   Health on server:   sudo bash ./scripts/stack.sh prod health
#   Logs on server:     sudo bash ./scripts/stack.sh prod logs
# ============================================================

# ------------------------------------------------------------
# 01 Runtime and container
# Use *_API_BIND_HOST=auto for QA/prod. Local should stay 127.0.0.1.
# PROD_API_PUBLIC_HOSTNAME is the server-side .lan hostname used behind edge Nginx.
# Public browser domain example: https://pacsapiapp.example.com/pacsApi
# ------------------------------------------------------------
TZ=Asia/Phnom_Penh
APP_IMAGE=udaya_pacs_prod_api:latest
API_COMPOSE_PROJECT_NAME=udaya_pacs_prod_api
PROD_API_CONTAINER_NAME=udaya_pacs_prod_api
PROD_API_PUBLIC_HOSTNAME=pacs-api.example.lan
PROD_API_BIND_HOST=auto
PROD_API_PORT=8082

# ------------------------------------------------------------
# 02 Storage and keys
# ------------------------------------------------------------
KEY_PATH=/var/ut-key
HOSPITAL_IMAGE_HOST_PATH=/home/Images
HOSPITAL_IMAGE_ROOT_PATH=/home/Images
PACS_APPLICATION_BRAND_ASSET_ROOT=/home/Images/application-brand
PACS_RESULT_UPLOAD_ROOT=/home/Images
PACS_DICOM_UPLOAD_TEMP_HOST_PATH=/home/Images/tmp/dicom-upload
PACS_DICOM_UPLOAD_TEMP_DIR=/home/Images/tmp/dicom-upload
SPRING_SERVLET_MULTIPART_LOCATION=/home/Images/tmp/dicom-upload

# ------------------------------------------------------------
# 03 Database
# Use DB hostname, for example jdbc:postgresql://utdatabase.lan:5432/emr_pacs_db.
# ------------------------------------------------------------
PROD_SPRING_DATASOURCE_URL=jdbc:postgresql://pacs-db.example.lan:5432/emr_pacs_db
PROD_SPRING_DATASOURCE_USERNAME=pacs_app_prod_rw
PROD_SPRING_DATASOURCE_PASSWORD=CHANGE_ME_PROD_DB_PASSWORD

# ------------------------------------------------------------
# 04 Security and JWT
# ------------------------------------------------------------
PROD_SECURITY_JWT_REFRESH_TOKEN_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_REFRESH_TOKEN_KEY
SECURITY_JWT_PRIVATE_KEY=file:/app/config/key/private_key.pem
SECURITY_JWT_PUBLIC_KEY=file:/app/config/key/public_key.pem
SECURITY_JWT_KEY_ID=replace_with_stable_key_id

# ------------------------------------------------------------
# 05 Private upstream URLs, browser origins, and host aliases
# Keep API upstream URLs on private .lan hostnames. Public HTTPS domains are
# only browser origins handled by the edge Nginx/reverse proxy.
# Edge Nginx maps the public API domain to this .lan API service.
# API_HOST_ALIASES format: hostname:auto or hostname:ip. Leave blank when DNS works.
# ------------------------------------------------------------
PROD_API_AUTH_URL=http://pacs-api.example.lan:8082/pacsApi
PROD_SPRINGDOC_SERVER_URL=http://pacs-api.example.lan:8082/pacsApi
CORS_ALLOWED_ORIGINS=http://pacs-frontend.example.lan:4173,http://pacs-viewer.example.lan:3005,https://pacs.example.com,https://pacsviewer.example.com,https://pacsapiapp.example.com
CORS_ALLOW_CREDENTIALS=false
SECURITY_JWT_REFRESH_TOKEN_COOKIE_SECURE=false
SECURITY_JWT_REFRESH_TOKEN_COOKIE_SAME_SITE=Lax
API_HOST_ALIASES=

# ------------------------------------------------------------
# 06 Client allow-list
# ------------------------------------------------------------
APP_SECURITY_CLIENT_ALLOW_PATHS=/worklist/worklist-received-study
APP_SECURITY_CLIENT_ALLOW_CLIENT_IDS=

# ------------------------------------------------------------
# 07 PACS result API
# ------------------------------------------------------------
PACS_RESULT_STATIC_AUTH_ENABLED=true
PACS_RESULT_API_KEY=replace_with_matching_prod_result_api_key
PACS_RESULT_MAX_IMAGE_BYTES=10485760

# ------------------------------------------------------------
# 08 Redis cache
# ------------------------------------------------------------
APP_CACHE_PROVIDER=redis
APP_CACHE_TTL_SECONDS=600
APP_CACHE_MAX_ENTRIES=5000
APP_CACHE_REDIS_HEALTH_ENABLED=true
APP_CACHE_REDIS_KEY_PREFIX=udaya_pacs_prod
REDIS_IMAGE=redis:7-alpine
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_TIMEOUT=2s
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
PROD_REDIS_CONTAINER_NAME=udaya_pacs_prod_redis
PROD_REDIS_HOST_PORT=6381
PROD_REDIS_NETWORK_NAME=udaya_pacs_prod_network
PROD_REDIS_PASSWORD=CHANGE_ME_PROD_REDIS_PASSWORD

# ------------------------------------------------------------
# 09 DICOM upload, health, and package builder
# ------------------------------------------------------------
PACS_CACHE_SCHEDULER_ENABLED=true
PACS_PARTITION_SCHEDULER_ENABLED=true
PACS_DICOM_UPLOAD_INSTANCE_PARALLELISM=24
PACS_DICOM_UPLOAD_INSTANCE_MAX_ATTEMPTS=8
PACS_DICOM_UPLOAD_INSTANCE_RETRY_BACKOFF_MS=500
PACS_DICOM_UPLOAD_IN_MEMORY_ENTRY_MAX_BYTES=1048576
PACS_DICOM_UPLOAD_MAX_CONCURRENT_PROCESSING_JOBS=1
DICOM_SERVER_HEALTH_TIMEOUT_MS=5000
DICOM_SERVER_HEALTH_OFFLINE_FAILURE_THRESHOLD=3
DICOM_SERVER_HEALTH_OFFLINE_GRACE_MS=180000
PACS_DICOM_SERVER_PACKAGE_INCLUDE_BASE_IMAGE=true
PACS_DICOM_SERVER_BASE_IMAGE_ARCHIVE_HOST_PATH=./dicom-server-images/dicom_server_base.tar
PACS_DICOM_SERVER_BASE_IMAGE_ARCHIVE_CONTAINER_PATH=/app/dicom-server-images/dicom_server_base.tar
PACS_DICOM_SERVER_PACKAGE_BASE_IMAGE_ARCHIVE_PATH=/app/dicom-server-images/dicom_server_base.tar
PACS_DICOM_SERVER_PACKAGE_MAX_EMBEDDED_BASE_IMAGE_BYTES=536870912
PACS_DICOM_SERVER_PACKAGE_DOWNLOAD_TEMP_DIR=/home/Images/tmp/dicom-routing-downloads

# ------------------------------------------------------------
# 10 Optional integrations and deploy notifications
# ------------------------------------------------------------
PROD_SPRING_MAIL_USERNAME=
PROD_SPRING_MAIL_PASSWORD=
PROD_TELEGRAM_CHAT_ID=
PROD_TELEGRAM_API_TOKEN=
DEPLOY_TELEGRAM_ENABLED=true
DEPLOY_TELEGRAM_CHAT_ID=
DEPLOY_TELEGRAM_API_TOKEN=
