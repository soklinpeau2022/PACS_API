# Production API profile. Copy to .env.prod and edit values.

# Runtime
TZ=Asia/Phnom_Penh
APP_IMAGE=udaya_pacs_prod_api:latest
API_COMPOSE_PROJECT_NAME=udaya_pacs_prod_api
PROD_API_CONTAINER_NAME=udaya_pacs_prod_api
PROD_API_PORT=8082
KEY_PATH=/var/ut-key
HOSPITAL_IMAGE_HOST_PATH=/var/ut-image
HOSPITAL_IMAGE_ROOT_PATH=/var/ut-image

# Database
PROD_SPRING_DATASOURCE_URL=jdbc:postgresql://192.168.8.11:5432/emr_pacs_db
PROD_SPRING_DATASOURCE_USERNAME=pacs_app_prod_rw
PROD_SPRING_DATASOURCE_PASSWORD=CHANGE_ME_PROD_DB_PASSWORD

# JWT
PROD_SECURITY_JWT_REFRESH_TOKEN_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_REFRESH_TOKEN_KEY
SECURITY_JWT_PRIVATE_KEY=file:/app/config/key/private_key.pem
SECURITY_JWT_PUBLIC_KEY=file:/app/config/key/public_key.pem
SECURITY_JWT_KEY_ID=replace_with_stable_key_id

# API URLs
PROD_API_AUTH_URL=http://192.168.8.10:8082/pacsApi
PROD_SPRINGDOC_SERVER_URL=http://192.168.8.10:8082/pacsApi

# Browser access
CORS_ALLOWED_ORIGINS=http://192.168.8.10:4173,http://192.168.8.10:3005
CORS_ALLOW_CREDENTIALS=true

# UDAYA_DICOM_SERVER callback clients
APP_SECURITY_CLIENT_ALLOW_PATHS=/worklist/worklist-received-study
APP_SECURITY_CLIENT_ALLOW_CLIENT_IDS=

# PACS result upload
PACS_RESULT_STATIC_AUTH_ENABLED=true
PACS_RESULT_API_KEY=replace_with_matching_prod_result_api_key
PACS_RESULT_UPLOAD_ROOT=/var/ut-image
PACS_RESULT_MAX_IMAGE_BYTES=10485760

# Optional integrations
PROD_SPRING_MAIL_USERNAME=
PROD_SPRING_MAIL_PASSWORD=
PROD_TELEGRAM_CHAT_ID=
PROD_TELEGRAM_API_TOKEN=

# Deploy Telegram notifications
DEPLOY_TELEGRAM_ENABLED=true
DEPLOY_TELEGRAM_CHAT_ID=
DEPLOY_TELEGRAM_API_TOKEN=
REDIS_MAXMEMORY_POLICY=allkeys-lru
APP_CACHE_PROVIDER=redis
REDIS_PORT=6379
REDIS_MAXMEMORY=512mb
REDIS_IMAGE=redis:7-alpine
APP_CACHE_MAX_ENTRIES=5000
REDIS_DATABASE=0
APP_CACHE_TTL_SECONDS=600
REDIS_TIMEOUT=2s
APP_CACHE_REDIS_HEALTH_ENABLED=true
APP_CACHE_REDIS_KEY_PREFIX=udaya_pacs_prod
PROD_REDIS_CONTAINER_NAME=udaya_pacs_prod_redis
PROD_REDIS_HOST_PORT=6381
PROD_REDIS_NETWORK_NAME=udaya_pacs_prod_network
PROD_REDIS_PASSWORD=CHANGE_ME_PROD_REDIS_PASSWORD
