<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ut.emrPacs.mapper.user.UserPermissionMapper">

    <insert id="createPermission">
        INSERT INTO role_module_details (
            role_id,
            module_detail_id,
            created
        ) VALUES (
            #{roleId},
            #{moduleId},
            NOW()
        )
        ON CONFLICT (role_id, module_detail_id) DO NOTHING
    </insert>

    <insert id="deletePermission">
        DELETE FROM role_module_details WHERE role_id = #{roleId}
    </insert>

</mapper>
